# Contentful credentials — copy to .env.local and fill with your own space values.
# Settings → API keys in your Contentful dashboard.
CONTENTFUL_SPACE_ID=your_space_id
CONTENTFUL_ACCESS_TOKEN=your_delivery_api_token
CONTENTFUL_PREVIEW_ACCESS_TOKEN=your_preview_api_token
# Set to "true" locally to fetch unpublished entries via the Preview API.
CONTENTFUL_PREVIEW=false

# --- Server-side: webhooks, migrations, seed, scheduled audit ----------------
# Content Management API token (Settings → API keys → Content management tokens).
# Different from the delivery/preview tokens above — grants write access.
CONTENTFUL_MANAGEMENT_TOKEN=your_cma_token
CONTENTFUL_ENVIRONMENT=master

# Shared secret the Contentful webhooks send as the `x-webhook-secret` header.
# Set the same value here and in each webhook's custom header so the API routes
# can reject forged calls. Leave blank to disable the check (local only).
CONTENTFUL_WEBHOOK_SECRET=change_me

# --- Contentful App deploys (used by GitHub Actions / app-scripts) -----------
CONTENTFUL_ORG_ID=your_org_id
EDITORIAL_TOOLKIT_APP_ID=your_editorial_toolkit_app_definition_id
RICH_TEXT_EDITOR_APP_ID=your_rich_text_editor_app_definition_id
# CMA token used only by the CI upload-ci scripts (can equal the management token).
CONTENTFUL_CMA_TOKEN=your_cma_token
