{
  "name": "rich-text-editor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A custom PlateJS-based Rich Text field editor for Contentful that serialises to/from the Contentful Rich Text document model.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "create-app": "contentful-app-scripts create-app-definition",
    "upload": "npm run build && contentful-app-scripts upload --bundle-dir ./dist",
    "upload-ci": "contentful-app-scripts upload-ci --bundle-dir ./dist --organization-id $CONTENTFUL_ORG_ID --definition-id $RICH_TEXT_EDITOR_APP_ID --token $CONTENTFUL_CMA_TOKEN"
  },
  "dependencies": {
    "@contentful/app-sdk": "^4.53.0",
    "@contentful/f36-components": "^4.81.0",
    "@contentful/f36-icons": "^4.0.0",
    "@contentful/f36-tokens": "^4.0.0",
    "@contentful/react-apps-toolkit": "^1.2.16",
    "@contentful/rich-text-types": "^16.8.0",
    "@platejs/basic-nodes": "^52.3.0",
    "@platejs/link": "^52.3.0",
    "platejs": "^52.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "slate": "^0.123.0",
    "slate-react": "^0.123.0"
  },
  "devDependencies": {
    "@contentful/app-scripts": "^2.5.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.0"
  }
}
