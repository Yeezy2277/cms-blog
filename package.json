{
  "name": "lumen-cms-blog",
  "version": "1.0.0",
  "private": true,
  "description": "A headless-CMS content platform built with Next.js (App Router), TypeScript and Contentful.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "seed": "node scripts/seed.mjs",
    "bootstrap": "contentful space migration --space-id \"$CONTENTFUL_SPACE_ID\" --environment-id \"${CONTENTFUL_ENVIRONMENT:-master}\" --management-token \"$CONTENTFUL_MANAGEMENT_TOKEN\" --yes content-model/migrations/000-create-content-types.cjs",
    "migrate": "contentful space migration --space-id \"$CONTENTFUL_SPACE_ID\" --environment-id \"${CONTENTFUL_ENVIRONMENT:-master}\" --management-token \"$CONTENTFUL_MANAGEMENT_TOKEN\" --yes content-model/migrations/001-add-editorial-fields.cjs"
  },
  "dependencies": {
    "@contentful/rich-text-plain-text-renderer": "^17.1.6",
    "@contentful/rich-text-react-renderer": "^16.0.1",
    "@contentful/rich-text-types": "^17.1.0",
    "contentful": "^11.0.0",
    "contentful-management": "^11.0.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "contentful-cli": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "typescript": "^5.7.2"
  }
}
